{
  "name": "netstar-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:safari": "wxt build --browser safari",
    "build:all": "wxt build && wxt build --browser firefox && wxt build --browser safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:all": "wxt zip && wxt zip --browser firefox",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "docs": "jsdoc -c jsdoc.config.json",
    "docs:watch": "jsdoc -c jsdoc.config.json --watch"
  },
  "dependencies": {
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.22",
    "jest": "^30.2.0",
    "jsdoc": "^4.0.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vite": "^7.3.2",
    "wxt": "^0.20.25"
  }
}
